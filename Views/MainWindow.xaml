<Window x:Class="WindowsTweaks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowsTweaks Pro - Оптимизация Windows | by Виталий Николаевич (vitalikkontr)"
        Height="580" Width="820"
        MinHeight="460" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <!-- Внешняя тень + скругление -->
    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.65"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ШАПКА
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                CornerRadius="10,10,0,0"
                Padding="10,5"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                <!-- Лого + Название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="24" Height="24"
                            Background="{StaticResource PrimaryGlowBrush}"
                            CornerRadius="5"
                            Margin="0,0,7,0">
                        <Image Source="pack://application:,,,/app_icon.png"
                               Width="16" Height="16"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Windows"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Text="Tweaks"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="4,0,0,0"/>
                            <Border Background="{StaticResource PrimaryGlowBrush}"
                                    CornerRadius="3"
                                    Padding="3,1"
                                    Margin="5,2,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="PRO"
                                           FontSize="7"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="by Виталий Николаевич (vitalikkontr)"
                                   FontSize="9"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Статус-индикатор строго по центру -->
                <Border Grid.Column="1"
                        HorizontalAlignment="Center"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="9,3"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6"
                                 Fill="{StaticResource AccentBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Готов к работе"
                                   Foreground="{StaticResource TextDimBrush}"
                                   FontSize="10"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Правые: Справка + О программе + кнопки окна -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Справка"
                            Style="{StaticResource ModernButton}"
                            Click="HelpButton_Click"
                            Background="{StaticResource CardBrush}"
                            Margin="3,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="О программе"
                            Style="{StaticResource ModernButton}"
                            Click="AboutButton_Click"
                            Background="{StaticResource CardBrush}"
                            Margin="3,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <!-- Разделитель -->
                    <Rectangle Width="1" Height="16"
                               Fill="{StaticResource BorderBrush}"
                               Margin="6,0" VerticalAlignment="Center"/>

                    <!-- Свернуть -->
                    <Button x:Name="BtnMinimize"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnMinimize_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Margin="1,0"
                            ToolTip="Свернуть">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="─" Foreground="{StaticResource TextDimBrush}"
                                               FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{StaticResource HoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Развернуть/восстановить -->
                    <Button x:Name="BtnMaximize"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnMaximize_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Margin="1,0"
                            ToolTip="Развернуть">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="□" Foreground="{StaticResource TextDimBrush}"
                                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{StaticResource HoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Закрыть -->
                    <Button x:Name="BtnClose"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnClose_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Margin="1,0"
                            ToolTip="Закрыть">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" CornerRadius="4">
                                    <TextBlock Text="✕" Foreground="{StaticResource TextDimBrush}"
                                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#8B2020"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>


        <!-- ═══════════════════════════════════════════
             ТЕЛО: САЙДБАР + КОНТЕНТ
        ════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Боковая навигация -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="6,8">
                <DockPanel>

                    <!-- Заголовок навигации -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="НАВИГАЦИЯ"
                               Style="{StaticResource SectionHeader}"
                               Margin="8,0,0,8"/>

                    <ListBox x:Name="NavigationList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextBrush}"
                             SelectionChanged="NavigationList_SelectionChanged"
                             SelectedIndex="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"  Value="Transparent"/>
                                <Setter Property="Foreground"  Value="{StaticResource TextDimBrush}"/>
                                <Setter Property="Padding"     Value="7,6"/>
                                <Setter Property="Margin"      Value="0,1"/>
                                <Setter Property="Cursor"      Value="Hand"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="5"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Индикатор выбранного -->
                                                    <Border x:Name="ActiveBar"
                                                            Grid.Column="0"
                                                            Width="2" Height="14"
                                                            Background="{StaticResource AccentBrush}"
                                                            CornerRadius="2"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,7,0"
                                                            Visibility="Collapsed"/>
                                                    <ContentPresenter Grid.Column="1"
                                                                      VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder"  Property="Background"   Value="{StaticResource SelectBrush}"/>
                                                    <Setter TargetName="ActiveBar"   Property="Visibility"   Value="Visible"/>
                                                    <Setter Property="Foreground"    Value="{StaticResource TextBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder"  Property="Background"   Value="{StaticResource HoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Производительность" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔒" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Конфиденциальность" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Сеть" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎨" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Внешний вид" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Службы Windows" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👨‍💼" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Администрирование" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛠️" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Системные утилиты" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                </DockPanel>
            </Border>

            <!-- Основная область контента -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource Surface2Brush}">
                <Border Margin="8"
                        Padding="12"
                        Background="{StaticResource Surface2Brush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel x:Name="ContentPanel">
                        <!-- Контент загружается динамически -->
                    </StackPanel>
                </Border>
            </ScrollViewer>

        </Grid>


        <!-- ═══════════════════════════════════════════
             НИЖНЯЯ ПАНЕЛЬ СТАТУСА
        ════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,10,10"
                Padding="10,5">
            <DockPanel>

                <!-- Статус слева -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6"
                             Fill="{StaticResource AccentBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,7,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Готов к работе"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center"
                               FontSize="10"/>
                </StackPanel>

                <!-- Кнопки справа -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <Button Content="📁  Точка восстановления"
                            Style="{StaticResource ModernButton}"
                            Click="CreateRestorePoint_Click"
                            Background="{StaticResource CardBrush}"
                            Margin="3,0"/>
                    <Button Content="↩  Отменить изменения"
                            Style="{StaticResource DangerButton}"
                            Click="RevertChanges_Click"
                            Margin="3,0"/>
                    <Button Content="✓  Применить изменения"
                            Style="{StaticResource ModernButton}"
                            Click="ApplyChanges_Click"
                            Margin="3,0"/>
                </StackPanel>

            </DockPanel>
        </Border>

    </Grid>
    </Border>
</Window>
